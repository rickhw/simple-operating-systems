flowchart TD
    %% 定義節點樣式
    classDef asm fill:#f9d0c4,stroke:#e06666,stroke-width:2px,color:#000
    classDef clang fill:#cfe2f3,stroke:#6fa8dc,stroke-width:2px,color:#000
    classDef hw fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef clang_r3 fill:#d9ead3,stroke:#93c47d,stroke-width:2px,color:#000,stroke-dasharray: 5 5
    classDef grub fill:#d5a6bd,stroke:#a64d79,stroke-width:2px,color:#000
    classDef highlight fill:#ffe599,stroke:#d6b656,stroke-width:3px,color:#000
    classDef magic fill:#e4d7f5,stroke:#8e7cc3,stroke-width:3px,color:#000

    %% 系統啟動流程
    subgraph Boot ["1. 系統啟動與掛載 (Day 1-25)"]
        GRUB(("GRUB")) -->|"載入核心 & 模組"| boot["asm/boot.S"]:::asm
        boot -->|"傳遞 MBI"| kernel["kernel_main()"]:::clang
        kernel -->|"初始化 GDT/IDT/Paging"| init_sys["系統基礎建設"]:::clang
        kernel -->|"解析 MBR & 掛載 SimpleFS"| simplefs_c["lib/simplefs.c"]:::clang
        simplefs_c -.->|"跨磁區 LBA 讀寫"| HDD(("ATA 硬碟\n(hdd.img)")):::hw
        kernel -->|"將 GRUB 模組 (ELF)\n寫入實體硬碟"| simplefs_c
    end

    %% 排程與記憶體隔離核心 (Day 31-38)
    subgraph Scheduler ["2. 多工排程與宇宙隔離 (Day 31-38)"]
        PIT(("PIT (Timer)")):::hw -- "IRQ 0 (每秒百次)" --> CPU(("CPU")):::hw
        CPU -->|"觸發"| isr0["timer_handler"]:::clang
        isr0 -->|"呼叫"| schedule["schedule()\n(排程器)"]:::highlight

        schedule -->|"1. 更新狀態機\n(RUNNING/WAITING/DEAD)"| TaskQueue[("雙向環狀佇列\n(Ready Queue)")]:::clang
        schedule -->|"2. 尋找下一個任務"| TaskQueue
        schedule -->|"3. 呼叫"| switch_task["switch_task\n(Context Switch)"]:::magic

        switch_task -.->|"保存/載入 ESP"| Stack[("Kernel Stacks")]:::hw
        switch_task -.->|"【切換 CR3 宇宙】"| MMU(("MMU (Paging)")):::hw
        switch_task -->|"iret 降級或返回"| UserSpace
    end

    %% 行程生命週期與系統呼叫 (Day 34-40)
    subgraph Syscalls ["3. 行程生命週期與 IPC"]
        UserSpace["Ring 3 應用程式\n(Shell, apps)"]:::clang_r3 -- "int 0x80 (eax=8)" --> sys_fork["sys_fork()\n[細胞分裂]"]:::clang
        UserSpace -- "int 0x80 (eax=9)" --> sys_exec["sys_exec()\n[奪舍與重置]"]:::clang
        UserSpace -- "int 0x80 (eax=10)" --> sys_wait["sys_wait()\n[等待甦醒]"]:::clang
        UserSpace -- "int 0x80 (eax=11, 12)" --> sys_ipc["sys_send/recv\n[跨宇宙通訊]"]:::clang

        sys_fork -->|"複製堆疊與暫存器"| TaskQueue
        sys_exec -->|"建立全新 Page Dir"| MMU
        sys_wait -->|"標記 WAITING"| schedule
        sys_ipc -->|"存取"| IPC_Mailbox[("IPC Message Queue")]:::clang
    end

    %% 互動式 I/O (Day 30)
    subgraph IO ["4. 終端機互動 I/O"]
        Keyboard(("鍵盤")):::hw -- "IRQ 1" --> CPU
        CPU --> kbd_isr["keyboard_handler"]:::clang
        kbd_isr -->|"存入"| RingBuffer[("Ring Buffer")]:::clang

        UserSpace -- "sys_read (eax=4)" --> syscall_h["syscall_handler"]:::clang
        syscall_h -->|"若是 FD 0 (STDIN)"| RingBuffer
    end

    %% 使用者生態系與進階檔案系統 (Day 41-50)
    subgraph Phase5 ["5. User Space 生態系與進階 FS (Day 41-50)"]
        UserSpace -- "呼叫 libc" --> Libc_Mem["malloc / free\n(User Heap 管理)"]:::clang_r3
        UserSpace -- "路徑導航 / I/O" --> Libc_FS["mkdir, pwd, cd, rm, write"]:::clang_r3

        Libc_Mem -- "sys_sbrk (13)" --> syscall_h
        Libc_FS -- "Syscalls (14-19)" --> syscall_h

        syscall_h -->|"傳遞 CWD"| VFS["VFS 介面"]:::clang
        VFS -->|"呼叫"| PathEngine["SimpleFS 路徑解析引擎\n(處理 /a/b, ., ..)"]:::highlight
        PathEngine -->|"依賴"| BlockAlloc["全域磁區分配器\n(Superblock 管理)"]:::clang
        BlockAlloc -.->|"分配新空間"| HDD
        PathEngine -.->|"讀寫樹狀目錄結構"| HDD
    end
