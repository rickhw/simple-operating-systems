flowchart TD
    classDef clang fill:#cfe2f3,stroke:#6fa8dc,stroke-width:2px,color:#000
    classDef hw fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef interface fill:#fce5cd,stroke:#f6b26b,stroke-width:2px,color:#000,stroke-dasharray: 5 5

    App["User Application"] -->|"sys_read(fd, buffer, size)"| Syscall["Syscall Handler"]:::interface
    Syscall -->|"1. 查詢 fd_table 取得檔案節點"| VFS["VFS (虛擬檔案系統)"]:::clang

    subgraph FSLayer ["File System Layer"]
        VFS -->|"2. node->read()\n(多型指標路由)"| SimpleFS["SimpleFS 驅動"]:::clang
        SimpleFS -->|"3. 解析 Superblock/File Entry\n計算實體 LBA"| ATADriver["ATA 硬碟驅動\n(ata_read_sector)"]:::clang
    end

    subgraph HardwareLayer ["Hardware IO"]
        ATADriver -->|"4. PIO 模式通訊\n(等待 BSY/DRQ)"| Ports(("I/O Ports\n0x1F0-0x1F7")):::hw
        Ports <-->|"5. 磁區讀寫 (512 bytes)"| HDD[("虛擬硬碟 (hdd.img)")]:::hw
    end
