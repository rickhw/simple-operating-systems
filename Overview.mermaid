flowchart TD
    classDef hardware fill:#fff2cc,stroke:#d6b656,stroke-width:2px,color:#000
    classDef kernel fill:#cfe2f3,stroke:#6fa8dc,stroke-width:2px,color:#000
    classDef userspace fill:#d9ead3,stroke:#93c47d,stroke-width:2px,color:#000
    classDef interface fill:#fce5cd,stroke:#f6b26b,stroke-width:2px,color:#000,stroke-dasharray: 5 5

    subgraph UserSpace ["User Space (Ring 3) - [第 2, 3 階段完成]"]
        Shell["Interactive Shell\n(app.c)"]:::userspace
        FutureApps["Future Apps\n(ls, echo, etc.)"]:::userspace
    end

    subgraph SyscallLayer ["System Call Interface (int 0x80)"]
        Syscall["Syscall Handler\n(sys_read, sys_write, sys_getchar)"]:::interface
    end

    subgraph KernelSpace ["Kernel Space (Ring 0) - [第 1, 2 階段完成]"]
        subgraph ProcessMem ["行程與記憶體管理"]
            PMM["PMM (實體記憶體)"]:::kernel
            VMM["Paging (虛擬分頁)"]:::kernel
            Loader["ELF Loader (載入器)"]:::kernel
        end

        subgraph FSSubsystem ["檔案與儲存系統"]
            VFS["VFS (虛擬檔案系統)"]:::kernel
            SimpleFS["SimpleFS"]:::kernel
        end

        subgraph Interrupts ["中斷與硬體抽象"]
            IDT["IDT / ISR (中斷表)"]:::kernel
            Drivers["Drivers (鍵盤, Timer)"]:::kernel
            ATA["ATA Driver (硬碟)"]:::kernel
        end
    end

    subgraph Hardware ["Hardware Layer (硬體層)"]
        CPU(("x86 CPU")):::hardware
        RAM(("實體 RAM")):::hardware
        HDD[("ATA 硬碟\n(hdd.img)")]:::hardware
        KB>鍵盤輸入]:::hardware
        VGA{{VGA 螢幕}}:::hardware
    end

    %% 關聯線
    Shell & FutureApps -->|"請求系統服務"| Syscall
    Syscall -->|"路由轉發"| KernelSpace

    ProcessMem <--> RAM
    FSSubsystem <--> ATA
    ATA <--> HDD
    Interrupts <--> CPU
    KB --> Drivers
    Drivers --> VGA
