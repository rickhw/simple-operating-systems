flowchart TD
    classDef asm fill:#f9d0c4,stroke:#e06666,stroke-width:2px,color:#000
    classDef clang fill:#cfe2f3,stroke:#6fa8dc,stroke-width:2px,color:#000

    GRUB(("GRUB Bootloader")) -->|"Multiboot (載入核心)"| boot["asm/boot.S"]:::asm
    boot -->|"設定初始 16KB Stack\n跳轉至 C 語言"| kernel_main["kernel_main()"]:::clang

    subgraph CoreInit ["核心基礎建設 (Core Initialization)"]
        kernel_main -->|"1. 安全防護"| GDT_IDT["GDT & IDT 初始化"]:::clang
        GDT_IDT -.->|"lgdt / lidt"| CPU_HW((CPU 暫存器))

        kernel_main -->|"2. 記憶體管理"| MemInit["PMM & Paging 初始化"]:::clang
        MemInit -->|"啟動分頁機制"| HeapInit["Kernel Heap (128KB) 初始化"]:::clang

        kernel_main -->|"3. 系統服務"| SyscallInit["註冊 Syscall (isr128)"]:::clang
    end
